# =====================================================
# Environment Variables for Audit + App System
# =====================================================
 
# -----------------------------------------------------
# Node Environment
# -----------------------------------------------------
NODE_ENV=development
PORT=4000
BASE_URL=http://localhost:4000
FRONTEND_URL=http://localhost:3000/
 
# -----------------------------------------------------
# MySQL Configuration
# -----------------------------------------------------
 
 
# Database (App)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=task_manager_db
 
# -----------------------------------------------------
# Elasticsearch Configuration
# -----------------------------------------------------
ELASTICSEARCH_HOST=http://localhost:9200
ELASTICSEARCH_USERNAME=elastic
ELASTICSEARCH_PASSWORD=LQIsa7N4ZkhEUnZgWGxr
 
# -----------------------------------------------------
# Kibana Configuration
# -----------------------------------------------------
KIBANA_HOST=http://localhost:5601
 
# -----------------------------------------------------
# Logstash Configuration
# -----------------------------------------------------
LOGSTASH_JDBC_DRIVER_PATH=/path/to/mysql-connector-java-8.0.33.jar
LOGSTASH_POLL_INTERVAL=* * * * *
LOGSTASH_METADATA_PATH=/var/lib/logstash/.logstash_jdbc_last_run_audit_logs
 
# -----------------------------------------------------
# Redis Configuration
# -----------------------------------------------------
REQUIRE_REDIS=false
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://127.0.0.1:6379
 
# -----------------------------------------------------
# Audit System Configuration
# -----------------------------------------------------
AUDIT_ENCRYPTION_KEY=your-32-character-encryption-key-here
AUDIT_CIRCUIT_BREAKER_THRESHOLD=10
AUDIT_BATCH_SIZE=100
 
# -----------------------------------------------------
# Security / JWT
# -----------------------------------------------------
JWT_SECRET=change_this_secret
JWT_EXPIRES_IN=7d
SESSION_SECRET=your_session_secret_here
SECRET=change_this_secret
PASSWORD_EXPIRE_DAYS=60
ACCESS_TOKEN_EXPIRY_DAYS=15m
REFRESH_TOKEN_EXPIRY_DAYS=30d
 
# -----------------------------------------------------
# Email Configuration
# -----------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=nikhithakondreddy590@gmail.com
SMTP_PASS=tzki fbwi fmzr nnuv
SMTP_FROM=nikhithakondreddy590@gmail.com
COMPANY_NAME=NIVARA HOME FINANCE LTD
 
# Gmail (legacy support)
GMAIL_USER=nikhithakondreddy590@gmail.com
GMAIL_PASS=tzki fbwi fmzr nnuv
 
# -----------------------------------------------------
# Uploads
# -----------------------------------------------------
MAX_FILE_SIZE=26214400
